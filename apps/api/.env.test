# ──────────────────────────────────────────────────────
# MoodFit API — 테스트 환경 (API 키 없이 실행 가능)
# ──────────────────────────────────────────────────────

NODE_ENV=development
PORT=3001

# SQLite 사용 (PostgreSQL, Docker 불필요)
USE_SQLITE=true
SQLITE_PATH=moodfit-test.db

# 시드 데이터 자동 생성
# 앱 시작 시 테스트 유저(test@moodfit.com / test1234)와 의류 20개 자동 생성
SEED_DATA=true

# JWT (테스트용 고정 시크릿)
JWT_SECRET=test-jwt-secret-moodfit-dev
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=test-jwt-refresh-secret-moodfit-dev
JWT_REFRESH_EXPIRES_IN=30d

# CORS
CORS_ORIGIN=http://localhost:3000,http://localhost:3001,http://localhost:3002,http://localhost:3003,http://localhost:19006

# API 키 — 비워두면 Mock 모드 자동 적용
# ANTHROPIC_API_KEY=    ← 나중에 여기에 입력
# OPENWEATHER_API_KEY=  ← 나중에 여기에 입력

# Rate Limiting (테스트용 완화)
THROTTLE_TTL=60000
THROTTLE_LIMIT=1000
