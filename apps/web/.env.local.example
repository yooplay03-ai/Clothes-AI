# MoodFit Web — 테스트 환경
# 이 파일을 .env.local 로 복사 후 사용
# ──────────────────────────────────────────────────────

# API 서버 주소
NEXT_PUBLIC_API_URL=http://localhost:3001

# 날씨 API 키 — 없으면 서버에서 Mock 날씨 데이터 반환
# NEXT_PUBLIC_WEATHER_API_KEY=   ← 나중에 여기에 입력
